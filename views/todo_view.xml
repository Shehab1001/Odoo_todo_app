<odoo>
    <record id="all_tasks_action" model="ir.actions.act_window">
        <field name="name">To-Do App</field>
        <field name="res_model">todo.task</field>
    </record>

    <record id="task_action_close" model="ir.actions.server">
        <field name="name">Close</field>
        <field name="model_id" ref="model_todo_task"/>
        <field name="binding_model_id" ref="model_todo_task"/>
        <field name="state">code</field>
        <field name="code">
            action = records.action_close()
        </field>
    </record>

    <record id="check_due_date_cron" model="ir.cron">
        <field name="name">check due date</field>
        <field name="model_id" ref="model_todo_task"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="state">code</field>
        <field name="code">model.check_due_date()</field>
    </record>


    <menuitem
            id="all_tasks_action_menu"
            name="All Tasks"
            parent="todo_sub_menu"
            action="all_tasks_action"
    />


    <record id="todo_tree_view" model="ir.ui.view">
        <field name="name">todo tree</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <tree multi_edit="1" class="table_style" decoration-danger="(is_late)">
                <field name="task_name"/>
                <field name="assign_to"/>
                <field name="description"/>
                <field name="due_date"/>
                <field name="status"/>
                <field name="is_late" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="todo_form_view" model="ir.ui.view">
        <field name="name">todo form</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="task_name"/>
                            <field name="assign_to"/>
                            <field name="description"/>
                            <field name="is_late" invisible="1"/>
                        </group>

                        <group>
                            <field name="status" widget="statusbar" options="{'clickable': 1}"/>
                            <field name="due_date"/>
                            <field name="estimated_time"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Timesheets">
                            <field name="timesheet_ids">
                                <tree editable="bottom">
                                    <field name="description"/>
                                    <field name="total_time" sum="total time"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


    <record id="todo_search" model="ir.ui.view">
        <field name="name">todo search</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <search>
                <field name="task_name"/>
                <field name="assign_to"/>

                <filter name="status" string="New Tasks" domain="[('status','=','new')]"/>
                <filter name="status" string="In Progress Tasks" domain="[('status','=','in_progress')]"/>
                <filter name="status" string="Completed Tasks" domain="[('status','=','completed')]"/>

                <filter name="assign_to" string="Assign To" context="{'group_by':'assign_to'}"/>
                <filter name="due_date" string="Due Date" context="{'group_by':'due_date'}"/>
                <filter name="status" string="Status" context="{'group_by':'status'}"/>

            </search>
        </field>
    </record>
</odoo>